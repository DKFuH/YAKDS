generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// Benutzer (light)
// ─────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  password_hash String
  tenant_id     String?
  branch_id     String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  projects   Project[]
  dashboard_configs DashboardConfig[]
  tenant     Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: SetNull)
  branch     Branch?   @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  favorites  UserFavorite[]   // Phase 5 – Sprint 43
  model_templates ModelTemplate[]  // Phase 5 – Sprint 43

  @@map("users")
}

// ─────────────────────────────────────────
// Projekte
// ─────────────────────────────────────────

model Project {
  id                String    @id @default(uuid())
  user_id           String
  name              String
  description       String?
  status            ProjectStatus @default(active)
  project_status    ProjectWorkflowStatus @default(lead)
  deadline          DateTime?
  priority          ProjectPriority @default(medium)
  assigned_to       String?
  progress_pct      Int @default(0)
  lead_status       LeadStatus @default(new)
  quote_value       Float?
  close_probability Int?
  tenant_id         String?
  branch_id         String?
  advisor           String?   // Phase 4 – Sprint 34: Fachberater/Sachbearbeiter
  sales_rep         String?   // Phase 4 – Sprint 34: Verkäufer (for branch filter)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  user              User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tenant            Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: SetNull)
  branch            Branch?   @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  versions          ProjectVersion[]
  rooms             Room[]
  quotes            Quote[]
  render_jobs       RenderJob[]
  import_jobs       ImportJob[]
  ifc_import_jobs   IfcImportJob[]
  documents         Document[]
  catalog_indices   CatalogIndex[]
  project_contacts  ProjectContact[]
  customer_price_lists CustomerPriceList[]
  customer_discounts CustomerDiscount[]
  project_line_items ProjectLineItem[]
  project_block_evaluations ProjectBlockEvaluation[]
  areas             Area[]    // Phase 4 – Sprint 32: Bereiche
  purchase_orders   PurchaseOrder[]   // Phase 5 – Sprint 35: Bestellverwaltung
  site_surveys      SiteSurvey[]      // Phase 6 – Sprint 47: Aufmaß
  production_orders ProductionOrder[] // Phase 6 – Sprint 46: Produktionsaufträge
  building_levels   BuildingLevel[]
  vertical_connections VerticalConnection[]
  quote_lines         Json      @default("[]")
  pricing_groups_json Json      @default("[]")
  macros              Json      @default("[]")

  @@map("projects")
}

enum ProjectStatus {
  active
  archived
}

enum ProjectWorkflowStatus {
  lead
  planning
  quoted
  contract
  production
  installed
  archived
}

enum ProjectPriority {
  low
  medium
  high
}

enum LeadStatus {
  new
  qualified
  quoted
  won
  lost
}

enum BlockBasis {
  purchase_price
  sell_price
  points
}

// ─────────────────────────────────────────
// Projektversionierung
// ─────────────────────────────────────────

model ProjectVersion {
  id          String    @id @default(uuid())
  project_id  String
  version     Int
  snapshot    Json      // vollständiger Projektstand als JSON
  label       String?
  created_at  DateTime  @default(now())

  project     Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([project_id, version])
  @@map("project_versions")
}

// ─────────────────────────────────────────
// Räume
// ─────────────────────────────────────────

model Room {
  id                  String    @id @default(uuid())
  project_id          String
  level_id            String?
  name                String
  ceiling_height_mm   Int       @default(2500)
  boundary            Json      // { vertices: Vertex[], wall_segments: WallSegment[] }
  ceiling_constraints Json      @default("[]")
  openings            Json      @default("[]")
  placements          Json      @default("[]")
  worktop_schemas     Json      @default("[]")
  measure_lines       Json      @default("[]")
  section_lines       Json      @default("[]")
  comments            Json      @default("[]")
  coloring            Json      @default("{\"surfaces\":[]}")
  ceiling_openings    Json      @default("[]")
  deco_objects        Json      @default("[]")
  lighting_profiles   Json      @default("[]")
  reference_image     Json?     // { url, x, y, rotation, scale, opacity }
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  project             Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  level               BuildingLevel? @relation(fields: [level_id], references: [id], onDelete: SetNull)

  @@index([project_id, level_id])

  @@map("rooms")
}

model BuildingLevel {
  id               String   @id @default(uuid())
  tenant_id        String
  project_id       String
  name             String   @db.VarChar(120)
  elevation_mm     Int      @default(0)
  height_mm        Int?
  order_index      Int      @default(0)
  visible          Boolean  @default(true)
  config_json      Json     @default("{}")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  project          Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  rooms            Room[]
  from_connections VerticalConnection[] @relation("VerticalConnectionFromLevel")
  to_connections   VerticalConnection[] @relation("VerticalConnectionToLevel")
  layout_sheets    LayoutSheet[]

  @@index([tenant_id, project_id, order_index])
  @@map("building_levels")
}

model VerticalConnection {
  id             String   @id @default(uuid())
  tenant_id      String
  project_id     String
  from_level_id  String
  to_level_id    String
  kind           String   @db.VarChar(40)
  footprint_json Json
  stair_json     Json     @default("{}")
  opening_json   Json     @default("{}")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  project        Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  from_level     BuildingLevel @relation("VerticalConnectionFromLevel", fields: [from_level_id], references: [id], onDelete: Cascade)
  to_level       BuildingLevel @relation("VerticalConnectionToLevel", fields: [to_level_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, project_id])
  @@map("vertical_connections")
}

// ─────────────────────────────────────────
// PHASE 8 – Sprint 59: 2D-Bemaßung
// ─────────────────────────────────────────

model Dimension {
  id         String        @id @default(uuid())
  room_id    String
  type       DimensionType
  points     Json
  style      Json          @default("{}")
  label      String?
  ref_a_type String?
  ref_a_id   String?
  ref_b_type String?
  ref_b_id   String?
  auto_update Boolean      @default(false)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  @@index([room_id])
  @@map("dimensions")
}

model Centerline {
  id         String   @id @default(uuid())
  room_id    String
  label      String?
  x0_mm      Float
  y0_mm      Float
  x1_mm      Float
  y1_mm      Float
  style      Json     @default("{}")
  ref_type   String?
  ref_id     String?
  created_at DateTime @default(now())

  @@index([room_id])
  @@map("centerlines")
}

// ─────────────────────────────────────────
// PHASE 11 – Sprint 64: Layout-Sheets & Detail-Views
// ─────────────────────────────────────────

model LayoutSheet {
  id         String          @id @default(uuid())
  project_id String
  level_id   String?
  name       String          @db.VarChar(100)
  sheet_type LayoutSheetType @default(floorplan)
  position   Int             @default(0)
  config     Json            @default("{}")
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  views      LayoutView[]
  level      BuildingLevel?  @relation(fields: [level_id], references: [id], onDelete: SetNull)

  @@index([project_id])
  @@index([level_id])
  @@map("layout_sheets")
}

model LayoutView {
  id         String      @id @default(uuid())
  sheet_id   String
  view_type  ViewType
  label      String?
  room_id    String?
  wall_id    String?
  clip_x_mm  Float?
  clip_y_mm  Float?
  clip_w_mm  Float?
  clip_h_mm  Float?
  scale      Float       @default(1.0)
  x_on_sheet Float       @default(0)
  y_on_sheet Float       @default(0)
  created_at DateTime    @default(now())

  sheet      LayoutSheet @relation(fields: [sheet_id], references: [id], onDelete: Cascade)

  @@index([sheet_id])
  @@map("layout_views")
}

model LayoutStylePreset {
  id                 String   @id @default(uuid())
  tenant_id          String
  name               String   @db.VarChar(120)
  text_height_mm     Float    @default(3.5)
  arrow_size_mm      Float    @default(2.5)
  line_width_mm      Float    @default(0.25)
  centerline_dash_mm Float    @default(6)
  symbol_scale_mm    Float    @default(10)
  font_family        String?  @db.VarChar(120)
  config_json        Json     @default("{}")
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@index([tenant_id])
  @@map("layout_style_presets")
}

enum ConstraintType {
  horizontal
  vertical
  parallel
  perpendicular
  coincident
  equal_length
  symmetry_axis
  driving_dimension
}

model GeometryConstraint {
  id          String         @id @default(uuid())
  tenant_id   String
  room_id     String
  type        ConstraintType
  target_refs Json           @default("[]")
  value_json  Json           @default("{}")
  enabled     Boolean        @default(true)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  @@index([tenant_id, room_id])
  @@map("geometry_constraints")
}

model PanoramaTour {
  id          String   @id @default(uuid())
  tenant_id   String
  project_id  String
  name        String   @db.VarChar(140)
  locale_code String?  @db.VarChar(10)
  points_json Json     @default("[]")
  share_token String?  @unique
  expires_at  DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([tenant_id, project_id])
  @@map("panorama_tours")
}

model SpecificationPackage {
  id            String   @id @default(uuid())
  tenant_id     String
  project_id    String
  name          String   @db.VarChar(140)
  locale_code   String?  @db.VarChar(10)
  config_json   Json     @default("{}")
  generated_at  DateTime?
  artifact_json Json     @default("{}")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([tenant_id, project_id])
  @@map("specification_packages")
}

model Cutlist {
  id           String   @id @default(uuid())
  project_id   String
  room_id      String?
  generated_at DateTime @default(now())
  parts        Json
  summary      Json

  @@index([project_id])
  @@map("cutlists")
}

enum NestingJobStatus {
  draft
  calculated
  exported
}

model NestingJob {
  id                String           @id @default(uuid())
  tenant_id         String
  project_id        String
  source_cutlist_id String
  sheet_width_mm    Int
  sheet_height_mm   Int
  kerf_mm           Int              @default(4)
  allow_rotate      Boolean          @default(true)
  status            NestingJobStatus @default(draft)
  result_json       Json             @default("{}")
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  @@index([tenant_id, project_id])
  @@index([source_cutlist_id])
  @@map("nesting_jobs")
}

enum LayoutSheetType {
  floorplan
  elevations
  installation
  detail
  section
}

enum ViewType {
  floorplan
  elevation
  section
  detail
  isometric
}

enum DimensionType {
  linear
  angular
  radial
  arc_length
  chord
}

// ─────────────────────────────────────────
// Kaufmännische Stammdaten
// ─────────────────────────────────────────

model TaxGroup {
  id        String  @id @default(uuid())
  name      String  // z.B. "Standard DE"
  tax_rate  Float   // z.B. 0.19

  catalog_items CatalogItem[]
  extra_costs   ExtraCost[]

  @@map("tax_groups")
}

model PriceList {
  id          String    @id @default(uuid())
  name        String
  valid_from  DateTime
  valid_until DateTime?
  created_at  DateTime  @default(now())

  items       PriceListItem[]

  @@map("price_lists")
}

model PriceListItem {
  id               String    @id @default(uuid())
  price_list_id    String
  catalog_item_id  String
  list_price_net   Float
  dealer_price_net Float

  price_list       PriceList    @relation(fields: [price_list_id], references: [id], onDelete: Cascade)
  catalog_item     CatalogItem  @relation(fields: [catalog_item_id], references: [id], onDelete: Cascade)

  @@unique([price_list_id, catalog_item_id])
  @@map("price_list_items")
}

model PricingGroup {
  id                   String  @id @default(uuid())
  name                 String  // z.B. "Küchenmöbel"
  default_discount_pct Float   @default(0)

  catalog_items CatalogItem[]

  @@map("pricing_groups")
}

// ─────────────────────────────────────────
// Katalog
// ─────────────────────────────────────────

model CatalogItem {
  id                  String       @id @default(uuid())
  sku                 String       @unique
  name                String
  type                CatalogItemType
  width_mm            Int
  height_mm           Int
  depth_mm            Int
  list_price_net      Float
  dealer_price_net    Float
  default_markup_pct  Float        @default(0)
  tax_group_id        String
  pricing_group_id    String?
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  tax_group           TaxGroup     @relation(fields: [tax_group_id], references: [id])
  pricing_group       PricingGroup? @relation(fields: [pricing_group_id], references: [id])
  price_list_items    PriceListItem[]

  @@map("catalog_items")
}

enum CatalogItemType {
  base_cabinet
  wall_cabinet
  tall_cabinet
  trim
  worktop
  appliance
  accessory
}

// ─────────────────────────────────────────
// Angebotseinstellungen
// ─────────────────────────────────────────

model QuoteSettings {
  id                     String  @id @default(uuid())
  project_id             String  @unique
  quote_number_prefix    String  @default("ANG")
  default_validity_days  Int     @default(30)
  default_free_text      String?
  default_footer_text    String?
  show_prices_on_quote   Boolean @default(true)
  show_item_numbers      Boolean @default(true)
  global_discount_pct    Float   @default(0)

  extra_costs ExtraCost[]

  @@map("quote_settings")
}

model ExtraCost {
  id               String        @id @default(uuid())
  quote_settings_id String
  label            String
  amount_net       Float
  tax_group_id     String
  type             ExtraCostType

  quote_settings   QuoteSettings @relation(fields: [quote_settings_id], references: [id], onDelete: Cascade)
  tax_group        TaxGroup      @relation(fields: [tax_group_id], references: [id])

  @@map("extra_costs")
}

enum ExtraCostType {
  freight
  assembly
  other
}

// ─────────────────────────────────────────
// Angebote (Platzhalter für Sprint 13)
// ─────────────────────────────────────────

model Quote {
  id           String      @id @default(uuid())
  project_id   String
  version      Int         @default(1)
  quote_number String
  status       QuoteStatus @default(draft)
  locale_code  String?     @db.VarChar(10)
  valid_until  DateTime
  free_text    String?
  footer_text  String?
  price_snapshot Json?
  created_at   DateTime    @default(now())

  project      Project     @relation(fields: [project_id], references: [id], onDelete: Cascade)
  items        QuoteItem[]

  @@map("quotes")
}

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  expired
}

model QuoteItem {
  id              String  @id @default(uuid())
  quote_id        String
  position        Int
  type            String
  description     String
  qty             Float
  unit            String
  unit_price_net  Float
  line_net        Float
  tax_rate        Float
  line_gross      Float
  notes           String?
  show_on_quote   Boolean @default(true)

  quote           Quote   @relation(fields: [quote_id], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

// ─────────────────────────────────────────
// Render-Jobs (Platzhalter für Sprint 15)
// ─────────────────────────────────────────

model CustomerPriceList {
  id                   String   @id @default(uuid())
  project_id           String
  name                 String
  price_adjustment_pct Float    @default(0)
  notes                String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  project              Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("customer_price_lists")
}

model CustomerDiscount {
  id           String   @id @default(uuid())
  project_id   String
  label        String
  discount_pct Float
  scope        String   @default("project")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  project      Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("customer_discounts")
}

model ProjectLineItem {
  id             String   @id @default(uuid())
  project_id      String
  source_type     String   @default("manual")
  description     String
  qty             Float
  unit            String
  unit_price_net  Float
  tax_rate        Float
  line_net        Float
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  project         Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("project_line_items")
}

model BlockProgram {
  id                  String                   @id @default(uuid())
  name                String
  manufacturer        String?
  notes               String?
  is_active           Boolean                  @default(true)
  created_at          DateTime                 @default(now())
  updated_at          DateTime                 @updatedAt

  groups              BlockGroup[]
  definitions         BlockDefinitionRecord[]
  conditions          BlockCondition[]
  project_evaluations ProjectBlockEvaluation[]

  @@map("block_programs")
}

model BlockGroup {
  id           String                  @id @default(uuid())
  program_id   String
  code         String
  name         String
  item_selector Json?
  created_at   DateTime                @default(now())
  updated_at   DateTime                @updatedAt

  program      BlockProgram            @relation(fields: [program_id], references: [id], onDelete: Cascade)
  definitions  BlockDefinitionRecord[]

  @@unique([program_id, code])
  @@map("block_groups")
}

model BlockDefinitionRecord {
  id                     String                   @id @default(uuid())
  program_id             String
  block_group_id         String?
  name                   String
  basis                  BlockBasis
  tiers                  Json
  sort_order             Int                      @default(0)
  created_at             DateTime                 @default(now())
  updated_at             DateTime                 @updatedAt

  program                BlockProgram             @relation(fields: [program_id], references: [id], onDelete: Cascade)
  group                  BlockGroup?              @relation(fields: [block_group_id], references: [id], onDelete: SetNull)
  conditions             BlockCondition[]
  project_evaluations    ProjectBlockEvaluation[] @relation("BestBlockDefinition")

  @@map("block_definitions")
}

model BlockCondition {
  id                  String                 @id @default(uuid())
  program_id          String
  block_definition_id String?
  field               String
  operator            String                 @default("gte")
  value               Json
  created_at          DateTime               @default(now())
  updated_at          DateTime               @updatedAt

  program             BlockProgram           @relation(fields: [program_id], references: [id], onDelete: Cascade)
  block_definition    BlockDefinitionRecord? @relation(fields: [block_definition_id], references: [id], onDelete: Cascade)

  @@map("block_conditions")
}

model ProjectBlockEvaluation {
  id                       String                 @id @default(uuid())
  project_id               String
  program_id               String
  best_block_definition_id String?
  price_summary            Json
  evaluations              Json
  best_block               Json?
  created_at               DateTime               @default(now())

  project                  Project                @relation(fields: [project_id], references: [id], onDelete: Cascade)
  program                  BlockProgram           @relation(fields: [program_id], references: [id], onDelete: Cascade)
  best_block_definition    BlockDefinitionRecord? @relation("BestBlockDefinition", fields: [best_block_definition_id], references: [id], onDelete: SetNull)

  @@map("project_block_evaluations")
}

model RenderJob {
  id             String          @id @default(uuid())
  project_id     String
  status         RenderJobStatus @default(queued)
  scene_payload  Json?
  worker_id      String?
  assigned_at    DateTime?
  started_at     DateTime?
  completed_at   DateTime?
  error_message  String?
  created_at     DateTime        @default(now())

  project        Project         @relation(fields: [project_id], references: [id], onDelete: Cascade)
  result         RenderJobResult?

  @@map("render_jobs")
}

model RenderNode {
  id           String           @id @default(uuid())
  node_name    String?
  status       RenderNodeStatus @default(active)
  last_seen_at DateTime         @default(now())
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt

  @@map("render_nodes")
}

enum RenderJobStatus {
  queued
  assigned
  running
  done
  failed
}

enum RenderNodeStatus {
  active
  offline
}

model RenderJobResult {
  id             String    @id @default(uuid())
  job_id         String    @unique
  image_url      String
  width_px       Int
  height_px      Int
  render_time_ms Int
  created_at     DateTime  @default(now())

  job            RenderJob @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@map("render_job_results")
}

// ─────────────────────────────────────────
// Import-Jobs (Platzhalter für Sprint 3.5)
// ─────────────────────────────────────────

model ImportJob {
  id               String          @id @default(uuid())
  project_id       String
  status           ImportJobStatus @default(queued)
  source_format    String          // dxf | dwg | skp
  source_filename  String
  file_size_bytes  Int
  import_asset     Json?
  protocol         Json            @default("[]")
  error_message    String?
  created_at       DateTime        @default(now())
  completed_at     DateTime?

  project          Project         @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("import_jobs")
}

enum ImportJobStatus {
  queued
  processing
  done
  failed
}

// ─────────────────────────────────────────
// PHASE 7 – Sprint 52: IFC BIM-Integration
// ─────────────────────────────────────────

model IfcImportJob {
  id           String       @id @default(uuid())
  project_id   String
  filename     String
  status       IfcJobStatus @default(pending)
  result       Json?
  error        String?
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt

  project      Project      @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@map("ifc_import_jobs")
}

enum IfcJobStatus {
  pending
  processing
  done
  failed
}

// ─────────────────────────────────────────
// PHASE 3 – Sprint 26: Dokumentenmanagement
// ─────────────────────────────────────────

model Document {
  id          String       @id @default(uuid())
  project_id  String
  tenant_id   String
  filename    String
  original_filename String?
  mime_type   String
  size_bytes  Int
  uploaded_by String
  uploaded_at DateTime     @default(now())
  type        DocumentType
  source_kind DocumentSourceKind @default(manual_upload)
  source_id   String?
  storage_provider String   @default("local_fs")
  storage_bucket String?
  storage_key String
  storage_version Int       @default(1)
  external_url String?
  tags        String[]     @default([])
  is_public   Boolean      @default(false)

  project     Project      @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, project_id])
  @@index([project_id, type])
  @@index([tenant_id, source_kind, source_id])
  @@map("documents")
}

enum DocumentType {
  quote_pdf
  render_image
  cad_import
  email
  contract
  other
}

enum DocumentSourceKind {
  manual_upload
  quote_export
  render_job
  import_job
}

// ─────────────────────────────────────────
// PHASE 3 – Sprint 28: Dashboards / KPIs
// ─────────────────────────────────────────

model DashboardConfig {
  id         String   @id @default(uuid())
  user_id    String
