generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// Benutzer (light)
// ─────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  password_hash String
  tenant_id     String?
  branch_id     String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  projects   Project[]
  dashboard_configs DashboardConfig[]
  tenant     Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: SetNull)
  branch     Branch?   @relation(fields: [branch_id], references: [id], onDelete: SetNull)

  @@map("users")
}

// ─────────────────────────────────────────
// Projekte
// ─────────────────────────────────────────

model Project {
  id                String    @id @default(uuid())
  user_id           String
  name              String
  description       String?
  status            ProjectStatus @default(active)
  project_status    ProjectWorkflowStatus @default(lead)
  deadline          DateTime?
  priority          ProjectPriority @default(medium)
  assigned_to       String?
  progress_pct      Int @default(0)
  lead_status       LeadStatus @default(new)
  quote_value       Float?
  close_probability Int?
  tenant_id         String?
  branch_id         String?
  advisor           String?   // Phase 4 – Sprint 34: Fachberater/Sachbearbeiter
  sales_rep         String?   // Phase 4 – Sprint 34: Verkäufer (for branch filter)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  user              User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tenant            Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: SetNull)
  branch            Branch?   @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  versions          ProjectVersion[]
  rooms             Room[]
  quotes            Quote[]
  render_jobs       RenderJob[]
  import_jobs       ImportJob[]
  documents         Document[]
  catalog_indices   CatalogIndex[]
  project_contacts  ProjectContact[]
  customer_price_lists CustomerPriceList[]
  customer_discounts CustomerDiscount[]
  project_line_items ProjectLineItem[]
  project_block_evaluations ProjectBlockEvaluation[]
  areas             Area[]    // Phase 4 – Sprint 32: Bereiche
  quote_lines         Json      @default("[]")
  pricing_groups_json Json      @default("[]")
  macros              Json      @default("[]")

  @@map("projects")
}

enum ProjectStatus {
  active
  archived
}

enum ProjectWorkflowStatus {
  lead
  planning
  quoted
  contract
  production
  installed
  archived
}

enum ProjectPriority {
  low
  medium
  high
}

enum LeadStatus {
  new
  qualified
  quoted
  won
  lost
}

enum BlockBasis {
  purchase_price
  sell_price
  points
}

// ─────────────────────────────────────────
// Projektversionierung
// ─────────────────────────────────────────

model ProjectVersion {
  id          String    @id @default(uuid())
  project_id  String
  version     Int
  snapshot    Json      // vollständiger Projektstand als JSON
  label       String?
  created_at  DateTime  @default(now())

  project     Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([project_id, version])
  @@map("project_versions")
}

// ─────────────────────────────────────────
// Räume
// ─────────────────────────────────────────

model Room {
  id                  String    @id @default(uuid())
  project_id          String
  name                String
  ceiling_height_mm   Int       @default(2500)
  boundary            Json      // { vertices: Vertex[], wall_segments: WallSegment[] }
  ceiling_constraints Json      @default("[]")
  openings            Json      @default("[]")
  placements          Json      @default("[]")
  worktop_schemas     Json      @default("[]")
  measure_lines       Json      @default("[]")
  section_lines       Json      @default("[]")
  comments            Json      @default("[]")
  coloring            Json      @default("{\"surfaces\":[]}")
  deco_objects        Json      @default("[]")
  lighting_profiles   Json      @default("[]")
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  project             Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("rooms")
}

// ─────────────────────────────────────────
// Kaufmännische Stammdaten
// ─────────────────────────────────────────

model TaxGroup {
  id        String  @id @default(uuid())
  name      String  // z.B. "Standard DE"
  tax_rate  Float   // z.B. 0.19

  catalog_items CatalogItem[]
  extra_costs   ExtraCost[]

  @@map("tax_groups")
}

model PriceList {
  id          String    @id @default(uuid())
  name        String
  valid_from  DateTime
  valid_until DateTime?
  created_at  DateTime  @default(now())

  items       PriceListItem[]

  @@map("price_lists")
}

model PriceListItem {
  id               String    @id @default(uuid())
  price_list_id    String
  catalog_item_id  String
  list_price_net   Float
  dealer_price_net Float

  price_list       PriceList    @relation(fields: [price_list_id], references: [id], onDelete: Cascade)
  catalog_item     CatalogItem  @relation(fields: [catalog_item_id], references: [id], onDelete: Cascade)

  @@unique([price_list_id, catalog_item_id])
  @@map("price_list_items")
}

model PricingGroup {
  id                   String  @id @default(uuid())
  name                 String  // z.B. "Küchenmöbel"
  default_discount_pct Float   @default(0)

  catalog_items CatalogItem[]

  @@map("pricing_groups")
}

// ─────────────────────────────────────────
// Katalog
// ─────────────────────────────────────────

model CatalogItem {
  id                  String       @id @default(uuid())
  sku                 String       @unique
  name                String
  type                CatalogItemType
  width_mm            Int
  height_mm           Int
  depth_mm            Int
  list_price_net      Float
  dealer_price_net    Float
  default_markup_pct  Float        @default(0)
  tax_group_id        String
  pricing_group_id    String?
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  tax_group           TaxGroup     @relation(fields: [tax_group_id], references: [id])
  pricing_group       PricingGroup? @relation(fields: [pricing_group_id], references: [id])
  price_list_items    PriceListItem[]

  @@map("catalog_items")
}

enum CatalogItemType {
  base_cabinet
  wall_cabinet
  tall_cabinet
  trim
  worktop
  appliance
  accessory
}

// ─────────────────────────────────────────
// Angebotseinstellungen
// ─────────────────────────────────────────

model QuoteSettings {
  id                     String  @id @default(uuid())
  project_id             String  @unique
  quote_number_prefix    String  @default("ANG")
  default_validity_days  Int     @default(30)
  default_free_text      String?
  default_footer_text    String?
  show_prices_on_quote   Boolean @default(true)
  show_item_numbers      Boolean @default(true)
  global_discount_pct    Float   @default(0)

  extra_costs ExtraCost[]

  @@map("quote_settings")
}

model ExtraCost {
  id               String        @id @default(uuid())
  quote_settings_id String
  label            String
  amount_net       Float
  tax_group_id     String
  type             ExtraCostType

  quote_settings   QuoteSettings @relation(fields: [quote_settings_id], references: [id], onDelete: Cascade)
  tax_group        TaxGroup      @relation(fields: [tax_group_id], references: [id])

  @@map("extra_costs")
}

enum ExtraCostType {
  freight
  assembly
  other
}

// ─────────────────────────────────────────
// Angebote (Platzhalter für Sprint 13)
// ─────────────────────────────────────────

model Quote {
  id           String      @id @default(uuid())
  project_id   String
  version      Int         @default(1)
  quote_number String
  status       QuoteStatus @default(draft)
  valid_until  DateTime
  free_text    String?
  footer_text  String?
  price_snapshot Json?
  created_at   DateTime    @default(now())

  project      Project     @relation(fields: [project_id], references: [id], onDelete: Cascade)
  items        QuoteItem[]

  @@map("quotes")
}

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  expired
}

model QuoteItem {
  id              String  @id @default(uuid())
  quote_id        String
  position        Int
  type            String
  description     String
  qty             Float
  unit            String
  unit_price_net  Float
  line_net        Float
  tax_rate        Float
  line_gross      Float
  notes           String?
  show_on_quote   Boolean @default(true)

  quote           Quote   @relation(fields: [quote_id], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

// ─────────────────────────────────────────
// Render-Jobs (Platzhalter für Sprint 15)
// ─────────────────────────────────────────

model CustomerPriceList {
  id                   String   @id @default(uuid())
  project_id           String
  name                 String
  price_adjustment_pct Float    @default(0)
  notes                String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  project              Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("customer_price_lists")
}

model CustomerDiscount {
  id           String   @id @default(uuid())
  project_id   String
  label        String
  discount_pct Float
  scope        String   @default("project")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  project      Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("customer_discounts")
}

model ProjectLineItem {
  id             String   @id @default(uuid())
  project_id      String
  source_type     String   @default("manual")
  description     String
  qty             Float
  unit            String
  unit_price_net  Float
  tax_rate        Float
  line_net        Float
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  project         Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("project_line_items")
}

model BlockProgram {
  id                  String                   @id @default(uuid())
  name                String
  manufacturer        String?
  notes               String?
  is_active           Boolean                  @default(true)
  created_at          DateTime                 @default(now())
  updated_at          DateTime                 @updatedAt

  groups              BlockGroup[]
  definitions         BlockDefinitionRecord[]
  conditions          BlockCondition[]
  project_evaluations ProjectBlockEvaluation[]

  @@map("block_programs")
}

model BlockGroup {
  id           String                  @id @default(uuid())
  program_id   String
  code         String
  name         String
  item_selector Json?
  created_at   DateTime                @default(now())
  updated_at   DateTime                @updatedAt

  program      BlockProgram            @relation(fields: [program_id], references: [id], onDelete: Cascade)
  definitions  BlockDefinitionRecord[]

  @@unique([program_id, code])
  @@map("block_groups")
}

model BlockDefinitionRecord {
  id                     String                   @id @default(uuid())
  program_id             String
  block_group_id         String?
  name                   String
  basis                  BlockBasis
  tiers                  Json
  sort_order             Int                      @default(0)
  created_at             DateTime                 @default(now())
  updated_at             DateTime                 @updatedAt

  program                BlockProgram             @relation(fields: [program_id], references: [id], onDelete: Cascade)
  group                  BlockGroup?              @relation(fields: [block_group_id], references: [id], onDelete: SetNull)
  conditions             BlockCondition[]
  project_evaluations    ProjectBlockEvaluation[] @relation("BestBlockDefinition")

  @@map("block_definitions")
}

model BlockCondition {
  id                  String                 @id @default(uuid())
  program_id          String
  block_definition_id String?
  field               String
  operator            String                 @default("gte")
  value               Json
  created_at          DateTime               @default(now())
  updated_at          DateTime               @updatedAt

  program             BlockProgram           @relation(fields: [program_id], references: [id], onDelete: Cascade)
  block_definition    BlockDefinitionRecord? @relation(fields: [block_definition_id], references: [id], onDelete: Cascade)

  @@map("block_conditions")
}

model ProjectBlockEvaluation {
  id                       String                 @id @default(uuid())
  project_id               String
  program_id               String
  best_block_definition_id String?
  price_summary            Json
  evaluations              Json
  best_block               Json?
  created_at               DateTime               @default(now())

  project                  Project                @relation(fields: [project_id], references: [id], onDelete: Cascade)
  program                  BlockProgram           @relation(fields: [program_id], references: [id], onDelete: Cascade)
  best_block_definition    BlockDefinitionRecord? @relation("BestBlockDefinition", fields: [best_block_definition_id], references: [id], onDelete: SetNull)

  @@map("project_block_evaluations")
}

model RenderJob {
  id             String          @id @default(uuid())
  project_id     String
  status         RenderJobStatus @default(queued)
  scene_payload  Json?
  worker_id      String?
  assigned_at    DateTime?
  started_at     DateTime?
  completed_at   DateTime?
  error_message  String?
  created_at     DateTime        @default(now())

  project        Project         @relation(fields: [project_id], references: [id], onDelete: Cascade)
  result         RenderJobResult?

  @@map("render_jobs")
}

model RenderNode {
  id           String           @id @default(uuid())
  node_name    String?
  status       RenderNodeStatus @default(active)
  last_seen_at DateTime         @default(now())
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt

  @@map("render_nodes")
}

enum RenderJobStatus {
  queued
  assigned
  running
  done
  failed
}

enum RenderNodeStatus {
  active
  offline
}

model RenderJobResult {
  id             String    @id @default(uuid())
  job_id         String    @unique
  image_url      String
  width_px       Int
  height_px      Int
  render_time_ms Int
  created_at     DateTime  @default(now())

  job            RenderJob @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@map("render_job_results")
}

// ─────────────────────────────────────────
// Import-Jobs (Platzhalter für Sprint 3.5)
// ─────────────────────────────────────────

model ImportJob {
  id               String          @id @default(uuid())
  project_id       String
  status           ImportJobStatus @default(queued)
  source_format    String          // dxf | dwg | skp
  source_filename  String
  file_size_bytes  Int
  import_asset     Json?
  protocol         Json            @default("[]")
  error_message    String?
  created_at       DateTime        @default(now())
  completed_at     DateTime?

  project          Project         @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("import_jobs")
}

enum ImportJobStatus {
  queued
  processing
  done
  failed
}

// ─────────────────────────────────────────
// PHASE 3 – Sprint 26: Dokumentenmanagement
// ─────────────────────────────────────────

model Document {
  id          String       @id @default(uuid())
  project_id  String
  tenant_id   String
  filename    String
  original_filename String?
  mime_type   String
  size_bytes  Int
  uploaded_by String
  uploaded_at DateTime     @default(now())
  type        DocumentType
  source_kind DocumentSourceKind @default(manual_upload)
  source_id   String?
  storage_provider String   @default("local_fs")
  storage_bucket String?
  storage_key String
  storage_version Int       @default(1)
  external_url String?
  tags        String[]     @default([])
  is_public   Boolean      @default(false)

  project     Project      @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, project_id])
  @@index([project_id, type])
  @@index([tenant_id, source_kind, source_id])
  @@map("documents")
}

enum DocumentType {
  quote_pdf
  render_image
  cad_import
  email
  contract
  other
}

enum DocumentSourceKind {
  manual_upload
  quote_export
  render_job
  import_job
}

// ─────────────────────────────────────────
// PHASE 3 – Sprint 28: Dashboards / KPIs
// ─────────────────────────────────────────

model DashboardConfig {
  id         String   @id @default(uuid())
  user_id    String
  tenant_id  String
  widgets    Json     @default("[]")
  layout     Json     @default("{}")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id])
  @@index([tenant_id, user_id])
  @@map("dashboard_configs")
}

// ─────────────────────────────────────────
// PHASE 3 – Sprint 29: Katalogindexierung
// ─────────────────────────────────────────

model CatalogIndex {
  id             String   @id @default(uuid())
  project_id     String
  catalog_id     String
  purchase_index Float
  sales_index    Float
  applied_at     DateTime @default(now())
  applied_by     String

  project        Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id, applied_at])
  @@index([project_id, catalog_id])
  @@map("catalog_indices")
}

// ─────────────────────────────────────────
// PHASE 2 – Sprint 23: Multi-Tenant / Filialen
// ─────────────────────────────────────────

model Tenant {
  id         String   @id @default(uuid())
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  branches   Branch[]
  users      User[]
  projects   Project[]
  contacts   Contact[]
  settings   TenantSetting?
  backup_snapshots BackupSnapshot[]
  notification_events NotificationEvent[]

  @@map("tenants")
}

model TenantSetting {
  id                 String   @id @default(uuid())
  tenant_id          String   @unique
  logo_url           String?
  quote_template     String?
  currency_code      String   @default("EUR")
  email_from_name    String?
  email_from_address String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  tenant             Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model BackupSnapshot {
  id               String              @id @default(uuid())
  tenant_id        String
  scope            BackupScope         @default(daily_snapshot)
  status           BackupSnapshotStatus @default(done)
  storage_provider String              @default("local_fs")
  storage_bucket   String?
  storage_key      String
  entity_count     Int                 @default(0)
  triggered_by     String
  created_at       DateTime            @default(now())

  tenant           Tenant              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at])
  @@map("backup_snapshots")
}

enum BackupScope {
  daily_snapshot
  manual_snapshot
}

enum BackupSnapshotStatus {
  done
  failed
}

model NotificationEvent {
  id               String                    @id @default(uuid())
  tenant_id        String
  event_type       NotificationEventType
  entity_type      String
  entity_id        String
  recipient_email  String
  subject          String
  message          String
  delivery_status  NotificationDeliveryStatus @default(queued)
  metadata_json    Json                      @default("{}")
  created_at       DateTime                  @default(now())

  tenant           Tenant                    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at])
  @@index([tenant_id, event_type])
  @@map("notification_events")
}

enum NotificationEventType {
  project_status_changed
  document_uploaded
  document_deleted
  quote_created
  custom
}

enum NotificationDeliveryStatus {
  queued
  delivered
  failed
}

model Branch {
  id            String   @id @default(uuid())
  tenant_id     String
  name          String
  location_json Json?    // { street, city, country, … }
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  users         User[]
  projects      Project[]

  @@map("branches")
}

// ─────────────────────────────────────────
// PHASE 2 – Sprint 20: Herstellerkatalog
// ─────────────────────────────────────────

model Manufacturer {
  id         String          @id @default(uuid())
  name       String
  code       String          @unique  // z.B. "NOLTE", "NOBILIA"
  tenant_id  String?
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  articles   CatalogArticle[]

  @@map("manufacturers")
}

/// Artikel aus dem Herstellerkatalog  (≠ CatalogItem, der interne Legacy-Katalog bleibt bestehen)
model CatalogArticle {
  id              String          @id @default(uuid())
  manufacturer_id String
  sku             String
  name            String
  article_type    ArticleType     @default(base_cabinet)
  base_dims_json  Json            // { width_mm, height_mm, depth_mm }
  meta_json       Json            @default("{}")
  tenant_id       String?
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  manufacturer    Manufacturer    @relation(fields: [manufacturer_id], references: [id], onDelete: Cascade)
  options         ArticleOption[]
  variants        ArticleVariant[]
  prices          ArticlePrice[]
  generated_items GeneratedItem[]

  @@unique([manufacturer_id, sku])
  @@map("catalog_articles")
}

enum ArticleType {
  base_cabinet
  wall_cabinet
  tall_cabinet
  worktop
  plinth
  accessory
  trim
  appliance
}

model ArticleOption {
  id              String         @id @default(uuid())
  article_id      String
  option_key      String         // z.B. "front_color", "handle"
  option_type     String         // z.B. "enum", "dimension"
  constraints_json Json          @default("{}")
  created_at      DateTime       @default(now())

  article         CatalogArticle @relation(fields: [article_id], references: [id], onDelete: Cascade)

  @@map("article_options")
}

model ArticleVariant {
  id                  String         @id @default(uuid())
  article_id          String
  variant_key         String
  variant_values_json Json           // { option_key: value, … }
  dims_override_json  Json           @default("{}")
  created_at          DateTime       @default(now())

  article             CatalogArticle @relation(fields: [article_id], references: [id], onDelete: Cascade)

  @@map("article_variants")
}

model ArticlePrice {
  id           String         @id @default(uuid())
  article_id   String
  price_list_id String
  valid_from   DateTime
  valid_to     DateTime?
  list_net     Float
  dealer_net   Float
  tax_group_id String?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  article      CatalogArticle @relation(fields: [article_id], references: [id], onDelete: Cascade)

  @@map("article_prices")
}

// ─────────────────────────────────────────
// PHASE 2 – Sprint 21: Auto-Vervollständigung
// ─────────────────────────────────────────

model GeneratedItem {
  id                 String                   @id @default(uuid())
  project_id         String
  room_id            String?
  catalog_article_id String?
  item_type          GeneratedItemType
  /// Abmessungsinformationen / Optionsausprägungen
  params_json        Json                     @default("{}")
  /// qty in mm (Länge für Langteil) oder Stückzahl
  qty                Float
  unit               String                  @default("mm")
  label              String
  is_generated       Boolean                 @default(true)
  build_number       Int                     @default(1)
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt

  source_links       GeneratedItemSourceLink[]
  catalog_article    CatalogArticle?          @relation(fields: [catalog_article_id], references: [id], onDelete: SetNull)

  @@map("generated_items")
}

enum GeneratedItemType {
  worktop
  plinth
  side_panel
  handle
  connector
  end_cap
  other
}

/// Verknüpfung: welche Schrank-Instanz hat dieses Langteil ausgelöst?
model GeneratedItemSourceLink {
  id                  String        @id @default(uuid())
  generated_item_id   String
  source_placement_id String        // ID der PlacedObject-Referenz (in rooms.placements JSON)
  created_at          DateTime      @default(now())

  generated_item      GeneratedItem @relation(fields: [generated_item_id], references: [id], onDelete: Cascade)

  @@map("generated_item_source_links")
}

// ─────────────────────────────────────────
// PHASE 2 – Sprint 22: Rule Engine v2
// ─────────────────────────────────────────

model RuleDefinition {
  id          String          @id @default(uuid())
  rule_key    String          @unique
  category    RuleCategory
  severity    RuleSeverity    @default(warning)
  params_json Json            @default("{}")
  enabled     Boolean         @default(true)
  tenant_id   String?
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  violations  RuleViolation[]

  @@map("rule_definitions")
}

enum RuleCategory {
  collision
  clearance
  ergonomics
  completeness
  accessory
}

enum RuleSeverity {
  error
  warning
  hint
}

model RuleRun {
  id           String          @id @default(uuid())
  project_id   String
  run_at       DateTime        @default(now())
  summary_json Json            @default("{}")

  violations   RuleViolation[]

  @@map("rule_runs")
}

model RuleViolation {
  id                 String          @id @default(uuid())
  run_id             String
  rule_key           String
  rule_definition_id String?
  severity           RuleSeverity
  entity_refs_json   Json            @default("[]")
  message            String
  hint               String?
  auto_fix_possible  Boolean         @default(false)
  created_at         DateTime        @default(now())

  run                RuleRun         @relation(fields: [run_id], references: [id], onDelete: Cascade)
  rule_definition    RuleDefinition? @relation(fields: [rule_definition_id], references: [id], onDelete: SetNull)

  @@map("rule_violations")
}

// ─────────────────────────────────────────
// PHASE 2 – Sprint 24: Leads / Webplaner
// ─────────────────────────────────────────

model Lead {
  id              String      @id @default(uuid())
  tenant_id       String?
  contact_id      String?
  status          LeadStatus  @default(new)
  contact_json    Json        // { name, email, phone, … }
  consent_json    Json        @default("{}")
  room_json       Json        @default("{}")  // vereinfachte Raumgeometrie (Webplaner)
  cabinets_json   Json        @default("[]") // vereinfachte Schrankliste
  promoted_to_project_id String? @unique
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  contact         Contact?    @relation(fields: [contact_id], references: [id], onDelete: SetNull)

  @@map("leads")
}

// €€€€€€€€€€€€€€€€€€€€€€€€€€€€€
// PHASE 3 – Sprint 27: Kontakte / CRM-Light
// €€€€€€€€€€€€€€€€€€€€€€€€€€€€€

model Contact {
  id              String          @id @default(uuid())
  tenant_id       String
  type            ContactType     @default(end_customer)
  company         String?
  first_name      String?
  last_name       String
  email           String?
  phone           String?
  address_json    Json            @default("{}")
  lead_source     ContactLeadSource @default(other)
  budget_estimate Float?
  notes           String?
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  projects        ProjectContact[]
  leads           Lead[]

  @@index([tenant_id, last_name])
  @@index([tenant_id, email])
  @@map("contacts")
}

model ProjectContact {
  project_id   String
  contact_id   String
  is_primary   Boolean   @default(false)
  created_at   DateTime  @default(now())

  project      Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  contact      Contact   @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@id([project_id, contact_id])
  @@index([contact_id])
  @@map("project_contacts")
}

enum ContactType {
  end_customer
  architect
  contractor
}

enum ContactLeadSource {
  web_planner
  showroom
  referral
  other
}

// ─────────────────────────────────────────
// PHASE 4 – Sprint 32: Bereiche / Alternativen
// ─────────────────────────────────────────

model Area {
  id          String        @id @default(uuid())
  project_id  String
  name        String
  sort_order  Int           @default(0)
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt

  project      Project      @relation(fields: [project_id], references: [id], onDelete: Cascade)
  alternatives Alternative[]

  @@index([project_id])
  @@map("areas")
}

model Alternative {
  id            String         @id @default(uuid())
  area_id       String
  name          String
  is_active     Boolean        @default(false)
  sort_order    Int            @default(0)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt

  area          Area           @relation(fields: [area_id], references: [id], onDelete: Cascade)
  model_settings ModelSettings?

  @@index([area_id])
  @@map("alternatives")
}

/// Modell-/Indexeinstellungen (F7-Dialog) pro Alternative
model ModelSettings {
  id                  String      @id @default(uuid())
  alternative_id      String      @unique
  /// Küchenmodell
  manufacturer_name   String?
  model_name          String?
  handle_name         String?
  /// Arbeitsplatte
  worktop_model       String?
  worktop_color       String?
  /// Sockel / Abdeckboden
  plinth_height_mm    Int?
  cover_panel_enabled Boolean     @default(false)
  /// Raum
  room_height_mm      Int?
  wall_thickness_mm   Int?
  /// zusätzliche freie Felder
  extra_json          Json        @default("{}")
  created_at          DateTime    @default(now())
  updated_at          DateTime    @updatedAt

  alternative         Alternative @relation(fields: [alternative_id], references: [id], onDelete: Cascade)

  @@map("model_settings")
}

// ─────────────────────────────────────────
// PHASE 4 – Sprint 34: Workspace-Layout
// ─────────────────────────────────────────

model UserWorkspaceLayout {
  id         String   @id @default(uuid())
  user_id    String   @unique
  layout_json Json    @default("{}")  // { panels: { floorplan: {...}, perspective: {...}, elevation: {...} } }
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("user_workspace_layouts")
}
